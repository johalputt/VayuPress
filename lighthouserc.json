{
  "ci": {
    "collect": {
      "url": ["http://localhost:8080/", "http://localhost:8080/hello-vayupress"],
      "numberOfRuns": 3,
      "settings": {
        "preset": "desktop"
      }
    },
    "assert": {
      "//": "Target is 95+ across the board. Assertions are 'warn' so the audit reports scores without failing CI on runner-to-runner variance; tighten to 'error' once a baseline is established on your infra.",
      "assertions": {
        "categories:performance": ["warn", { "minScore": 0.9 }],
        "categories:accessibility": ["warn", { "minScore": 0.95 }],
        "categories:best-practices": ["warn", { "minScore": 0.95 }],
        "categories:seo": ["warn", { "minScore": 0.95 }]
      }
    },
    "upload": {
      "target": "temporary-public-storage"
    }
  }
}
