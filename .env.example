# VayuPress environment — copy to .env and edit. NEVER commit your real .env.
# Used by docker-compose.yml. See docs/INSTALLATION.md for the full variable list.

# REQUIRED — a strong, random admin API key (e.g. `openssl rand -hex 32`).
API_KEY=change-me-to-a-long-random-secret

# Your public domain (used for canonical URLs, sitemap, feed, CORS).
DOMAIN=localhost

# Build version stamp shown in the admin panel and /health.
VAYU_VERSION=docker

# --- Optional: Meilisearch (uncomment the service in docker-compose.yml) ------
# MEILI_MASTER_KEY=change-me-to-another-long-random-secret

# --- Optional: signed self-update (see docs/UPGRADING.md) ---------------------
# VAYU_SELFUPDATE_ENABLED=false
# VAYU_RELEASE_PUBKEY=


# --- VayuOS Phase 2: Mail (VayuMail) + PGP (VayuPGP) ---------------------------
# VayuMail activates automatically when DOMAIN is a real domain (not localhost).
# Outbound DKIM keys, the PGP keystore, and Maildir live under <dir(DB_PATH)>/vayudata/.
# The PGP at-rest encryption key is derived from API_KEY — keep API_KEY stable.
#
# Opt-in security-update watcher (privacy default = off). When "on" it fetches
# only public GitHub release metadata for the crypto dependencies powering
# VayuPGP/VayuMail and surfaces available patches in /os/vayuos/security.
# VAYUOS_SECURITY_UPDATES=off


# --- VayuOS Phase 2 (cont.): inbound mail ------------------------------------
# The SMTP/IMAP receive listeners start automatically once DOMAIN is set, so the
# instance can receive external mail. Set VAYUOS_MAIL_INBOUND=off to run
# outbound-only. Binding the ports is best-effort: a failed bind (e.g. :25
# without privileges) is surfaced in /os/vayuos but never blocks outbound/local
# delivery. Receiving external mail also needs port 25 reachable + MX/A records.
# VAYUOS_MAIL_INBOUND=on
# VAYUOS_MAIL_SMTP_LISTEN=:25
# VAYUOS_MAIL_IMAP_LISTEN=:143
# VAYUOS_MAIL_SUBMISSION_LISTEN=:587
# VAYUOS_MAIL_IMAPS_LISTEN=:993
# TLS for the mail listeners (STARTTLS on 25/587/143, implicit TLS on 993).
# Drop in a CA-signed cert (e.g. Let's Encrypt) for verified client use;
# when unset, VayuMail generates an in-memory self-signed cert so opportunistic
# STARTTLS still works out of the box.
# VAYUOS_MAIL_TLS_CERT=/etc/letsencrypt/live/mail.example.com/fullchain.pem
# VAYUOS_MAIL_TLS_KEY=/etc/letsencrypt/live/mail.example.com/privkey.pem
